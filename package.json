{
  "name": "AitiGuruTestTask",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run declarestyle:watch\" \"vite\"",
    "build": "npm run declarestyle && tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --fix --report-unused-disable-directives --max-warnings 0",
    "lint:css": "stylelint 'src/**/*.scss' --fix",
    "declarestyle": "typed-scss-modules 'src/**/*.scss' --nameFormat camel --ignore src/shared/styles/**/*.scss -p.~assets src/shared/styles",
    "declarestyle:watch": "typed-scss-modules src/**/*.scss --nameFormat camel --ignore src/shared/styles/**/*.scss -p.~assets src/shared/styles -w"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@hookform/resolvers": "^3.9.1",
    "classnames": "^2.5.1",
    "effector": "^23.2.2",
    "effector-react": "^23.2.1",
    "ky": "^1.7.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^7.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.4.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.4.2",
    "sass": "^1.83.4",
    "stylelint": "^16.12.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-order": "^6.0.4",
    "typed-scss-modules": "^8.1.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.7"
  }
}
